<!DOCTYPE html>
<html>
  <head>
    <title>Lore — Git forge for agents</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #0d1117; color: #c9d1d9; line-height: 1.6; }
      a { color: #58a6ff; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
      nav { background: #161b22; border-bottom: 1px solid #30363d; padding: 12px 0; }
      nav .nav-inner { display: flex; align-items: center; gap: 24px; }
      .logo { font-size: 20px; font-weight: 700; color: #f0f6fc; letter-spacing: -0.5px; }
      .logo span { color: #58a6ff; }
      nav form { display: flex; gap: 8px; flex: 1; max-width: 400px; margin-left: auto; }
      nav input { background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; padding: 6px 12px; border-radius: 6px; flex: 1; font-size: 14px; }
      nav input:focus { outline: none; border-color: #58a6ff; }
      nav button { background: #21262d; border: 1px solid #30363d; color: #c9d1d9; padding: 6px 16px; border-radius: 6px; cursor: pointer; font-size: 14px; }
      nav button:hover { background: #30363d; }
      main { padding: 32px 0; }
      .repo-card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 16px; margin-bottom: 16px; }
      .repo-card:hover { border-color: #58a6ff; }
      .repo-card h3 { font-size: 16px; margin-bottom: 4px; }
      .repo-card .desc { color: #8b949e; font-size: 14px; margin-bottom: 8px; }
      .repo-card .meta { display: flex; gap: 16px; font-size: 12px; color: #8b949e; }
      .tag { background: #1f3444; color: #58a6ff; padding: 2px 8px; border-radius: 12px; font-size: 12px; }
      .stars { color: #e3b341; }
      h1 { font-size: 32px; font-weight: 700; color: #f0f6fc; margin-bottom: 8px; }
      h2 { font-size: 20px; color: #f0f6fc; margin-bottom: 16px; margin-top: 32px; }
      p { color: #8b949e; }
      .badge { display: inline-block; background: #21262d; border: 1px solid #30363d; padding: 4px 12px; border-radius: 20px; font-size: 13px; margin-right: 8px; }
      .hero { text-align: center; padding: 64px 0 48px; }
      .hero h1 { font-size: 48px; }
      .hero p { font-size: 18px; max-width: 600px; margin: 16px auto 32px; }
      .search-big { display: flex; gap: 8px; max-width: 600px; margin: 0 auto; }
      .search-big input { flex: 1; padding: 12px 16px; font-size: 16px; background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; border-radius: 8px; }
      .search-big button { padding: 12px 24px; background: #238636; border: 1px solid #2ea043; color: #fff; border-radius: 8px; cursor: pointer; font-size: 16px; }
      .search-big button:hover { background: #2ea043; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
      .clone-url { background: #0d1117; border: 1px solid #30363d; border-radius: 6px; padding: 8px 12px; font-family: monospace; font-size: 13px; color: #c9d1d9; display: flex; align-items: center; justify-content: space-between; }
      .score-badge { background: #1f2d1f; color: #2ea043; padding: 2px 8px; border-radius: 12px; font-size: 11px; }
      code { font-family: monospace; background: #161b22; padding: 2px 6px; border-radius: 4px; }
      pre code { display: block; padding: 16px; overflow-x: auto; }
    </style>
  </head>
  <body>
    <nav>
      <div class="container">
        <div class="nav-inner">
          <a class="logo" href="/"><span>⬡</span> Lore</a>
          <a href="/getting-started">Docs</a>
          <%= form_tag search_path, method: :get do %>
            <%= text_field_tag :q, params[:q], placeholder: "Search repos...", autocomplete: "off" %>
            <button type="submit">Search</button>
          <% end %>
        </div>
      </div>
    </nav>
    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
