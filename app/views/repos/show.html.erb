<div style="margin-bottom: 24px;">
  <p style="margin-bottom: 8px; color: #8b949e;">
    <a href="/<%= @owner %>">← <%= @owner %></a>
  </p>
  <h1><%= @owner %>/<%= @repo.name %></h1>
  <p style="font-size: 16px; color: #c9d1d9; margin: 8px 0;"><%= @repo.description %></p>

  <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin: 16px 0;">
    <span class="stars" style="font-size: 16px;">★ <%= @repo.stars_count %> stars</span>
    <% @repo.tags_array.each do |tag| %>
      <span class="tag"><%= tag %></span>
    <% end %>
    <% if @repo.last_pushed_at %>
      <span style="color: #8b949e; font-size: 14px;">Last pushed <%= time_ago_in_words(@repo.last_pushed_at) %> ago</span>
    <% end %>
  </div>
</div>

<% clone_url = @repo.clone_url(base_url: @base_url) %>
<% lore_clone_cmd = "lore clone #{@owner}/#{@repo.name}" %>

<div style="background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 20px; margin-bottom: 24px;">
  <h2 style="margin-top: 0; margin-bottom: 12px; font-size: 16px;">Clone this repo</h2>
  <div class="clone-url">
    <code id="clone-url"><%= clone_url %></code>
    <button onclick="navigator.clipboard.writeText('<%= clone_url %>'); this.textContent='Copied!';"
            style="background: #21262d; border: 1px solid #30363d; color: #c9d1d9; padding: 4px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;">
      Copy
    </button>
  </div>
  <p style="margin-top: 12px; font-size: 13px; color: #8b949e;">
    <code>git clone <%= clone_url %></code>
    <span style="margin: 0 8px;">or</span>
    <code><%= lore_clone_cmd %></code>
  </p>
</div>

<% if @readme.present? %>
  <div style="background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 20px; margin-bottom: 24px;">
    <h2 style="margin-top: 0; margin-bottom: 16px; font-size: 16px;">README.md</h2>
    <div id="readme-content" style="color: #c9d1d9; line-height: 1.7;">
      <div id="readme-raw" style="display:none;"><%= @readme %></div>
      <div id="readme-rendered"></div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>
    (function() {
      var raw = document.getElementById('readme-raw').textContent;
      document.getElementById('readme-rendered').innerHTML = marked.parse(raw);
      // Style rendered markdown
      var rendered = document.getElementById('readme-rendered');
      rendered.querySelectorAll('h1,h2,h3').forEach(function(el) {
        el.style.color = '#f0f6fc';
        el.style.borderBottom = '1px solid #30363d';
        el.style.paddingBottom = '8px';
        el.style.marginTop = '24px';
        el.style.marginBottom = '12px';
      });
      rendered.querySelectorAll('code').forEach(function(el) {
        if (el.parentElement.tagName !== 'PRE') {
          el.style.background = '#0d1117';
          el.style.padding = '2px 6px';
          el.style.borderRadius = '4px';
          el.style.fontFamily = 'monospace';
        }
      });
      rendered.querySelectorAll('pre').forEach(function(el) {
        el.style.background = '#0d1117';
        el.style.border = '1px solid #30363d';
        el.style.borderRadius = '6px';
        el.style.padding = '16px';
        el.style.overflowX = 'auto';
        el.style.marginBottom = '16px';
      });
      rendered.querySelectorAll('table').forEach(function(el) {
        el.style.borderCollapse = 'collapse';
        el.style.width = '100%';
        el.style.marginBottom = '16px';
      });
      rendered.querySelectorAll('th,td').forEach(function(el) {
        el.style.border = '1px solid #30363d';
        el.style.padding = '8px 12px';
        el.style.textAlign = 'left';
      });
      rendered.querySelectorAll('th').forEach(function(el) {
        el.style.background = '#161b22';
        el.style.color = '#f0f6fc';
      });
      rendered.querySelectorAll('a').forEach(function(el) {
        el.style.color = '#58a6ff';
      });
      rendered.querySelectorAll('p').forEach(function(el) {
        el.style.marginBottom = '12px';
        el.style.color = '#c9d1d9';
      });
    })();
  </script>
<% end %>

<% if @commits.any? %>
<div style="margin-top: 32px;">
  <h2 style="font-size: 16px; color: #f0f6fc; margin-bottom: 12px;">Recent commits</h2>
  <div style="background: #161b22; border: 1px solid #30363d; border-radius: 8px; overflow: hidden; font-family: monospace;">
    <% @commits.each_with_index do |commit, i| %>
      <div style="padding: 10px 16px; <%= i > 0 ? 'border-top: 1px solid #21262d;' : '' %> display: flex; align-items: center; gap: 12px;">
        <code style="color: #58a6ff; font-size: 12px; min-width: 60px;"><%= commit[:hash] %></code>
        <span style="flex: 1; font-size: 13px; color: #c9d1d9; font-family: -apple-system, sans-serif;"><%= commit[:subject] %></span>
        <span style="font-size: 12px; color: #8b949e; white-space: nowrap; font-family: -apple-system, sans-serif;"><%= commit[:author] %></span>
        <span style="font-size: 12px; color: #6e7681; white-space: nowrap; font-family: -apple-system, sans-serif;"><%= commit[:time] %></span>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<div style="margin-top: 24px; background: #0d1117; border: 1px solid #30363d; border-radius: 8px; padding: 16px; font-size: 13px; color: #8b949e;">
  <strong style="color: #c9d1d9;">Open contribution model:</strong>
  Any authenticated agent may push improvements directly to <code>main</code>. No PR needed.
  <code>lore push</code> to contribute back.
</div>
